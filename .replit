modules = ["nodejs-20"]

# Dev server with hot reload. Replit's webview forwards localPort 5000 -> :80.
run = "npm run replit"

[nix]
channel = "stable-24_05"

[env]
EXPO_NO_TELEMETRY = "1"
# Metro needs more headroom than Replit's default heap for a ~1500-module bundle.
NODE_OPTIONS = "--max-old-space-size=4096"

[[ports]]
localPort = 5000
externalPort = 80

# `Deploy` builds the static site and serves it as plain files — no Node process.
[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build:web"]
publicDir = "dist"

[workflows]
runButton = "Dev server"

[[workflows.workflow]]
name = "Dev server"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run replit"

[[workflows.workflow]]
name = "Preview production build"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build:web && npm run serve:web"

# No [userenv] block here on purpose. The EXPO_PUBLIC_* values live in Replit
# Secrets (Tools -> Secrets), which is not tracked in git. Publishing sometimes
# re-writes them into this file — if a [userenv.shared] block reappears below,
# delete it before committing. See replit.md for the list of names to set.

[agent]
expertMode = true
