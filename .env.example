# Copy this file to ".env" and fill in the values, then restart the dev server.
#
#   cp .env.example .env      (macOS/Linux)
#   copy .env.example .env    (Windows)
#
# Both vars MUST start with EXPO_PUBLIC_ so Expo inlines them into the JS bundle.
# Get the values from the project's Supabase dashboard → Settings → API,
# OR ask the project owner to send you the same two values so everyone shares
# one backend (the anon/publishable key is safe to share — it ships in the app).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ── Google Calendar (optional) ───────────────────────────────────────────────
# Powers the "Connect Google Calendar" button on the Schedule screen. This is
# the ONLY way to show real calendar events on the web build — expo-calendar
# reads the OS calendar, which doesn't exist in a browser.
#
# Leave these blank and the app still works: the Google option simply hides
# itself, and native builds keep using the device calendar.
#
# Create the clients at https://console.cloud.google.com/apis/credentials
# (enable the "Google Calendar API" first). You only need the ones you ship:
#
#   WEB     -> OAuth client type "Web application".
#              Add your site to "Authorized JavaScript origins",
#              e.g. http://localhost:8081 and https://<your-repl>.replit.dev
#   IOS     -> OAuth client type "iOS", bundle ID com.amitpathak.focus
#   ANDROID -> OAuth client type "Android", package com.amitpathak.focus
#
# For iOS/Android you must also register the reversed client ID as a URL scheme
# (com.googleusercontent.apps.<id>) in app.json before the native flow works.

EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
