{
  "expo": {
    "name": "Focus",
    "slug": "focus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "focus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "This app needs access to your health data to track sleep and screen time",
        "NSHealthUpdateUsageDescription": "This app needs access to your health data to store sleep information",
        "NSPhotoLibraryUsageDescription": "Focus uses your photo library so you can pick a custom profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.amitpathak.focus"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.QUERY_ALL_PACKAGES",
        "android.permission.PACKAGE_USAGE_STATS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.amitpathak.focus"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app.png",
          "color": "#6366F1"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Focus to access your calendar to show your schedule.",
          "remindersPermission": "Allow Focus to access your reminders."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Focus uses your photo library so you can pick a custom profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app.png",
          "imageWidth": 350,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "199e01cd-0234-4a63-b3c6-1a7b5c88287e"
      }
    }
  }
}
